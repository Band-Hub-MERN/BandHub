<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="80dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <!-- Account Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACCOUNT"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/colorSurface">

            <include
                android:id="@+id/rowUsername"
                layout="@layout/item_settings_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <View style="@style/Divider" />

            <include
                android:id="@+id/rowEmail"
                layout="@layout/item_settings_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- Preferences Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PREFERENCES"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/colorSurface">

            <include
                android:id="@+id/rowNotifications"
                layout="@layout/item_settings_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <View style="@style/Divider" />

            <include
                android:id="@+id/rowLocationServices"
                layout="@layout/item_settings_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <View style="@style/Divider" />

            <include
                android:id="@+id/rowPreferences"
                layout="@layout/item_settings_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- Support Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SUPPORT"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/colorSurface">

            <include
                android:id="@+id/rowHelp"
                layout="@layout/item_settings_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- Sign Out -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/colorSurface"
            android:layout_marginTop="20dp">

            <include
                android:id="@+id/rowSignOut"
                layout="@layout/item_settings_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
